# folo-tui credentials and settings.
#
# `tui folo --auth` (or `make auth`) captures your cookie to ~/.config/tui/env,
# which every run reads. This per-plugin .env is only an optional manual
# override for a source checkout:
#
#   cp .env.sample .env          # .env is gitignored; never commit your cookie
#   source .env && ./folo-tui
#
# Shell exports always win over the values set here.

# Browser session cookie (required). Normally captured by `tui folo --auth` into
# ~/.config/tui/env; to set it by hand here instead, copy the whole Cookie
# request header from a logged-in folo.is session (see the README
# "Authentication" section).
export FOLO_COOKIE='or paste your folo.is Cookie header here'

# folo-tui options. All optional; commented values are the defaults.

# Color theme: auto (match terminal background) | light | dark.
# export FOLO_TUI_THEME=auto

# Pending (unread) triage (true) vs all articles (false).
# export FOLO_TUI_UNREAD_ONLY=true

# Auto-refresh the list on this interval, e.g. 5m or 30s. Empty = off.
# export FOLO_TUI_REFRESH=

# How many articles to fetch per load (newest first).
# export FOLO_TUI_MAX=50

# Folo API host (only change if you self-host or use a different host).
# export FOLO_TUI_BASE_URL=https://api.folo.is

# Folo web app origin, sent as the Origin/Referer header.
# export FOLO_TUI_WEB_URL=https://app.folo.is

# Browser User-Agent sent with requests (defaults to a Chrome string).
# export FOLO_TUI_USER_AGENT=
