# inoreader-tui credentials and settings.
#
#   cp .env.sample .env          # .env is gitignored; never commit your cookie
#   make auth                    # opens a browser, you log in, cookie is written here
#   source .env && ./inoreader-tui
#
# To load it in every shell, add to ~/.zshrc:  source /path/to/inoreader-tui/.env
# Shell exports always win over the values set here.

# Browser session cookie (required). The `make auth` helper fills this in for you
# by driving a real browser with playwright-cli. To set it by hand instead, copy
# the whole Cookie request header from a logged-in inoreader.com session (see the
# README "Authentication" section).
export INOREADER_COOKIE='run `make auth` to fill this in'

# inoreader-tui options. All optional; commented values are the defaults.

# Color theme: auto (match terminal background) | light | dark.
# export INOREADER_TUI_THEME=auto

# Unread-only triage (true) vs the full "All articles" view (false).
# export INOREADER_TUI_UNREAD_ONLY=true

# Auto-refresh the list on this interval, e.g. 5m or 30s. Empty = off.
# export INOREADER_TUI_REFRESH=

# How many articles to fetch per load (oldest first).
# export INOREADER_TUI_MAX=50

# Inoreader site root (only change if you use a different host).
# export INOREADER_TUI_BASE_URL=https://www.inoreader.com

# Browser User-Agent sent with requests (defaults to a Chrome string).
# export INOREADER_TUI_USER_AGENT=
