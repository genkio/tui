# slack-tui credentials and settings.
#
# `tui slack --auth` (or `make auth`) captures browser-session tokens to
# ~/.config/tui/env, which every run reads. This per-plugin .env is only an
# optional manual override for a source checkout:
#
#   cp .env.sample .env          # .env is gitignored; never commit real tokens
#   source .env && ./slack-tui
#
# Shell exports always win over the values set here.

# Authentication, forwarded to slack-mcp-server. Pick ONE mode.

# OAuth user token (recommended; not tied to the browser-cookie expiry).
# export SLACK_MCP_XOXP_TOKEN=xoxp-...

# Browser-session tokens ("stealth"; full feature parity, incl. mentions_only).
# Tip: `tui slack --auth` opens a browser, you log in, and it captures both (plus
# the workspace domain) to ~/.config/tui/env. Otherwise extract them by hand
# (see the README).
export SLACK_MCP_XOXC_TOKEN=xoxc-...
export SLACK_MCP_XOXD_TOKEN=xoxd-...

# Bot token (limited: cannot list unreads).
# export SLACK_MCP_XOXB_TOKEN=xoxb-...

# Enable mark-as-read; the server disables it by default (true | 1 | yes).
export SLACK_MCP_MARK_TOOL=true

# Enable emoji reactions (press e); disabled by default (true | channel list | !C123).
# Custom-emoji search makes one direct read-only emoji.list call with the token above;
# an xoxp token needs the emoji:read scope.
export SLACK_MCP_REACTION_TOOL=true

# slack-tui options. All optional; commented values are the defaults.

# Workspace subdomain for the "open in browser" key (o), e.g. acme.slack.com -> acme.
# `tui slack --auth` captures this automatically (read from the workspace, not the URL).
export SLACK_TUI_SLACK_DOMAIN=

# Color theme: auto (match terminal background) | light | dark.
# export SLACK_TUI_THEME=auto

# Auto-refresh the unread list on this interval, e.g. 30s or 2m. Empty = off.
# export SLACK_TUI_REFRESH=

# Conversations to list: all | dm | group_dm | partner | internal.
# export SLACK_TUI_CHANNEL_TYPES=all

# Unread list sizing.
# export SLACK_TUI_MAX_CHANNELS=50
# export SLACK_TUI_MAX_MESSAGES=10

# Only conversations that mention you (browser-session tokens only).
# export SLACK_TUI_MENTIONS_ONLY=false

# How the MCP server is launched (advanced; defaults to the pinned npx package).
# export SLACK_TUI_SERVER_COMMAND=npx
# export SLACK_TUI_SERVER_ARGS="-y slack-mcp-server@1.3.0 --transport stdio"

# The server itself supports more SLACK_MCP_* vars (caches, proxy, TLS); see its docs.
