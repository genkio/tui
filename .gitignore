# launcher binary
/tui
# stray binary from `go build .` in cmd/tui (module base name is "tui")
/cmd/tui/tui

# built app binaries (each project also ignores its own)
/plugins/x/x-tui
/plugins/inoreader/inoreader-tui
/plugins/slack/slack-tui
/plugins/folo/folo-tui

# secrets, in any project
**/.env

# playwright capture data, in any project
**/.playwright-cli/
**/pw-profile/

go.work
go.work.sum
